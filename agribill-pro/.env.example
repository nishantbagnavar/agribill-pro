# ─── Server ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS — use your domain in production)
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────
DB_PATH=./data/agribill.db

# ─── JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ───
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_too

# ─── SMTP (optional — for email notifications) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ─── Sentry (optional — crash monitoring) ─────────────────────────
# Create free project at sentry.io → copy DSN here
# Leave blank during development
SENTRY_DSN=
VITE_SENTRY_DSN=

# ─── Supabase (required — license system) ─────────────────────────
# Create project at supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── License HMAC (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
LICENSE_HMAC_SECRET=your_32_char_random_secret

# ─── Cloudflare R2 (optional — SQLite backup) ─────────────────────
# Dashboard → R2 → Create bucket "agribill-backups" → API Tokens
# Endpoint format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=agribill-backups
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ─── Auto-Updater (leave blank to use local update-manifest.json) ─
UPDATE_MANIFEST_URL=

# ─── Telegram Alerts (optional — notified on new shop registration) ─
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Add bot to a group → send a message
# 3. GET https://api.telegram.org/bot<TOKEN>/getUpdates → copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
